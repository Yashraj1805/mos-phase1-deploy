# Copy this file to backend/.env and fill in real values.
# .env is auto-loaded by app.services.llm.llm_service at import time.

# --- LLM provider ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Database ---
DATABASE_URL=sqlite:///./mos_phase1.db
